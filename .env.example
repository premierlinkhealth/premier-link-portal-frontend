# Copy to `.env` (or set in Vercel project settings). All VITE_ vars are public
# (baked into the browser bundle) — that is expected for the Firebase web config
# and the API URL. No secrets go here.

# The deployed backend API (Cloud Run URL, or https://api.premierlinkhealth.com once mapped)
VITE_API_BASE_URL=https://premier-link-portal-api-95737693802.us-west2.run.app

# Google Identity Platform (Firebase) web config — from the Identity Platform
# console → Application setup details. apiKey here is a public client identifier.
VITE_FIREBASE_API_KEY=REPLACE_WITH_WEB_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=premier-link-portal.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=premier-link-portal
